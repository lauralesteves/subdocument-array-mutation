{
  "name": "subdocument-array-mutation",
  "version": "1.0.0",
  "description": "Serverless API for recursive subdocument array mutation operations",
  "main": "index.js",
  "scripts": {
    "docker": "docker-compose up --force-recreate",
    "dev": "yarn install; npx serverless offline start --noPrependStageInUrl --stage local --useSeparateProcesses",
    "test": "mocha --recursive test/unit/",
    "unit-test": "mocha --recursive test/unit/",
    "integration-test": "mocha --recursive test/integration/"
  },
  "keywords": [
    "api",
    "serverless",
    "lambda",
    "AWS"
  ],
  "author": "Guilherme Esteves <eu@guilhermesteves.dev>",
  "license": "MIT",
  "dependencies": {
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "mocha": "^11.7.5",
    "serverless": "^3.40.0",
    "serverless-domain-manager": "^7.4.0",
    "serverless-offline": "^14.5.0",
    "serverless-plugin-split-stacks": "^1.14.0",
    "sinon": "^21.0.2",
    "uuid": "^10.0.0"
  }
}
